# --- Supabase ---
# Dashboard > Project Settings > Data API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Dashboard > Project Settings > API Keys > anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dashboard > Project Settings > API Keys > service_role (server-only secret — NEVER expose to the client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk ---
# Clerk Dashboard > Configure > API Keys > Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk Dashboard > Configure > API Keys > Secret key
CLERK_SECRET_KEY=

# Clerk Dashboard > Configure > Webhooks > (your endpoint) > Signing Secret
CLERK_WEBHOOK_SECRET=

# --- Spotify (Client Credentials flow) ---
# developer.spotify.com/dashboard > (your app) > Settings > Client ID
SPOTIFY_CLIENT_ID=

# developer.spotify.com/dashboard > (your app) > Settings > View client secret
SPOTIFY_CLIENT_SECRET=
